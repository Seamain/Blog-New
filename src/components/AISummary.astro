---
import { generateAISummary } from "../api/AiSummary";

interface Props {
    content: string;
    title: string;
}

const { content, title } = Astro.props;

let summary = "";
let error = false;

try {
    summary = await generateAISummary(content, title);
} catch (e) {
    console.error("Failed to generate AI summary:", e);
    error = true;
}
---

<div class="ai-summary-container w-full mt-6 mb-6">
    <div class="relative rounded-xl overflow-hidden" style="border: 1px solid rgba(0,245,255,0.25); background: linear-gradient(135deg, rgba(13,27,42,0.95) 0%, rgba(26,13,42,0.95) 100%); box-shadow: 0 0 20px rgba(0,245,255,0.05), inset 0 0 30px rgba(0,0,0,0.3);">

        <!-- Top accent line -->
        <div class="w-full h-px" style="background: linear-gradient(to right, transparent, rgba(0,245,255,0.5), rgba(139,92,246,0.5), transparent);"></div>

        <div class="p-5">
            <!-- Header -->
            <div class="flex items-center gap-3 mb-4">
                <div class="flex items-center justify-center w-8 h-8 rounded-lg" style="background: rgba(0,245,255,0.1); border: 1px solid rgba(0,245,255,0.3);">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: #00F5FF;">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
                    </svg>
                </div>
                <div class="flex items-center gap-2">
                    <span class="cyber-font text-xs font-bold tracking-widest" style="color: #00F5FF;">[AI]</span>
                    <h3 class="text-sm font-bold" style="color: #e2e8f0; font-family: 'Noto Sans SC', sans-serif;">智能总结</h3>
                    <span class="cyber-font text-xs" style="color: rgba(139,92,246,0.6);">◇ DeepSeek</span>
                </div>
                <!-- Blinking cursor -->
                <div class="ml-auto flex items-center gap-1.5">
                    <div class="w-1.5 h-1.5 rounded-full" style="background: #00F5FF; animation: twinkle 1.5s ease-in-out infinite;"></div>
                    <div class="w-1.5 h-1.5 rounded-full" style="background: #8B5CF6; animation: twinkle 1.5s ease-in-out infinite; animation-delay: 0.3s;"></div>
                    <div class="w-1.5 h-1.5 rounded-full" style="background: #FF6B9D; animation: twinkle 1.5s ease-in-out infinite; animation-delay: 0.6s;"></div>
                </div>
            </div>

            <!-- Left accent bar -->
            <div class="flex gap-4">
                <div class="w-px shrink-0 rounded-full" style="background: linear-gradient(to bottom, #00F5FF, #8B5CF6, transparent);"></div>

                <div class="flex-1">
                    {!error && summary && (
                        <p class="text-sm leading-relaxed" style="color: #94a3b8; font-family: 'Noto Sans SC', sans-serif;">
                            {summary}
                        </p>
                    )}

                    {error && (
                        <p class="text-xs" style="color: rgba(255,107,157,0.7);">
                            〔 生成摘要失败，请稍后重试 〕
                        </p>
                    )}

                    {!error && !summary && (
                        <div class="flex items-center gap-3">
                            <div class="relative w-5 h-5">
                                <div class="absolute inset-0 border border-current rounded-full animate-spin" style="color: #00F5FF; border-top-color: transparent;"></div>
                            </div>
                            <span class="text-xs cyber-font" style="color: rgba(0,245,255,0.6);">正在生成摘要...</span>
                        </div>
                    )}
                </div>
            </div>
        </div>

        <!-- Bottom accent line -->
        <div class="w-full h-px" style="background: linear-gradient(to right, transparent, rgba(139,92,246,0.3), transparent);"></div>
    </div>
</div>

<style>
    .ai-summary-container {
        animation: fadeInUp 0.5s ease-out;
    }
</style>
