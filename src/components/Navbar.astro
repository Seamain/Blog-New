---
import { Icon } from "astro-icon/components";
import { getNavigationRender } from "../api/Navigation";
import type { Navigation } from "../interfaces/Navigation";

let navigations: Navigation[] = [];
try {
    navigations = (await getNavigationRender(
        "main-navigation",
    )) as Navigation[];
} catch (error) {
    console.error(
        "Failed to load navigation:",
        error instanceof Error ? error.message : String(error),
    );
    navigations = [];
}
---

<nav
    class="sticky top-0 z-40 w-full"
    style="border-bottom: 1px solid rgba(255,107,157,0.2); background: rgba(255,248,240,0.82); backdrop-filter: blur(14px) saturate(150%); -webkit-backdrop-filter: blur(14px) saturate(150%); will-change: transform; contain: layout style;"
    id="main-nav"
>
    <div
        class="relative flex w-full flex-row gap-4 px-6 py-3 not-sm:flex-row not-sm:items-center justify-between"
    >
        <!-- Mobile logo -->
        <a
            href="/"
            class="flex items-center gap-3 text-xl font-semibold tracking-tight md:hidden lg:hidden xl:hidden 2xl:hidden"
            aria-label="Seamain 首页"
        >
            <img
                class="rounded-full p-0.5"
                style="border: 1.5px solid rgba(255,107,157,0.5); box-shadow: 0 0 10px rgba(255,107,157,0.3);"
                src="https://storage.seamain.org/41C3EE1A37915E8E63F62929F89287B1.jpg"
                width="34"
                height="34"
                alt="Seamain 头像"
                loading="eager"
                fetchpriority="high"
            />
            <span class="acg-glow-text-pink font-bold">Seamain</span>
            <span class="text-xs cyber-font" style="color: rgba(139,92,246,0.7)"
                >✦</span
            >
        </a>

        <!-- Mobile controls -->
        <div
            class="relative flex w-full flex-row gap-4 px-2 not-sm:flex-row not-sm:items-center justify-between"
        >
            <!-- Desktop logo -->
            <a
                href="/"
                class="flex items-center gap-3 text-xl font-semibold tracking-tight not-sm:hidden not-md:hidden"
                aria-label="Seamain 首页"
            >
                <img
                    class="rounded-full p-0.5"
                    style="border: 1.5px solid rgba(255,107,157,0.5); box-shadow: 0 0 10px rgba(255,107,157,0.3);"
                    src="https://storage.seamain.org/41C3EE1A37915E8E63F62929F89287B1.jpg"
                    width="34"
                    height="34"
                    alt="Seamain 头像"
                    loading="eager"
                    fetchpriority="high"
                />
                <span class="acg-glow-text font-bold">Seamain</span>
            </a>

            <!-- Mobile controls group -->
            <div
                class="flex items-center gap-2 md:hidden lg:hidden xl:hidden 2xl:hidden"
            >
                <button
                    id="mobile-menu-button"
                    class="flex items-center justify-center p-2 rounded-lg transition"
                    style="color: #FF6B9D;"
                    aria-label="Toggle mobile menu"
                >
                    <svg
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                </button>

                <a
                    href="/search"
                    class="p-2 transition"
                    style="color: #8B5CF6;"
                    aria-label="搜索文章"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="17"
                        height="17"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.8"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <circle cx="10.5" cy="10.5" r="6.5"></circle>
                        <path d="M15.5 15.5 L21 21"></path>
                    </svg>
                </a>

                <button
                    id="mobile-theme-toggle"
                    class="flex items-center justify-center p-2 rounded-lg transition"
                    style="color: #FFE566;"
                    aria-label="Toggle theme"
                >
                    <svg
                        id="mobile-theme-toggle-light-icon"
                        class="w-5 h-5 hidden"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                    >
                        <path
                            d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"
                            fill-rule="evenodd"
                            clip-rule="evenodd"></path>
                    </svg>
                    <svg
                        id="mobile-theme-toggle-dark-icon"
                        class="w-5 h-5 hidden"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                    >
                        <path
                            d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"
                        ></path>
                    </svg>
                </button>
            </div>

            <!-- Desktop navigation -->
            <div
                class="not-sm:hidden not-md:hidden flex items-center justify-end gap-1"
            >
                {
                    navigations.map((item) => (
                        <a
                            href={"/" + item.path}
                            class="nav-link rounded-full px-4 py-1.5 text-sm font-medium transition-all duration-200"
                        >
                            {item.title}
                        </a>
                    ))
                }

                <a
                    href="/search"
                    class="p-2 transition ml-1"
                    style="color: #8B5CF6;"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="17"
                        height="17"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.8"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <circle cx="10.5" cy="10.5" r="6.5"></circle>
                        <path d="M15.5 15.5 L21 21"></path>
                    </svg>
                </a>

                <button
                    id="theme-toggle"
                    class="flex items-center justify-center p-2 rounded-lg ml-1 transition"
                    style="color: #FFE566;"
                    aria-label="Toggle theme"
                >
                    <svg
                        id="theme-toggle-light-icon"
                        class="w-5 h-5 hidden"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                    >
                        <path
                            d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"
                            fill-rule="evenodd"
                            clip-rule="evenodd"></path>
                    </svg>
                    <svg
                        id="theme-toggle-dark-icon"
                        class="w-5 h-5 hidden"
                        fill="currentColor"
                        viewBox="0 0 20 20"
                    >
                        <path
                            d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"
                        ></path>
                    </svg>
                </button>
            </div>
        </div>
    </div>

    <!-- Mobile navigation menu -->
    <div
        id="mobile-menu"
        class="hidden w-full shadow-lg"
        style="background: rgba(255,248,240,0.82); backdrop-filter: blur(14px) saturate(150%); -webkit-backdrop-filter: blur(14px) saturate(150%); border-top: 1px solid rgba(255,107,157,0.15);"
    >
        <div class="px-6 py-4 space-y-1 text-center flex flex-col items-center">
            {
                navigations.map((item) => (
                    <a
                        href={"/" + item.path}
                        class="block w-full max-w-sm rounded-xl px-4 py-3 text-base font-medium transition-all duration-200 nav-link"
                    >
                        {item.title}
                    </a>
                ))
            }
        </div>
    </div>

    <script>
        function getThemePreference(): string {
            const savedTheme = localStorage.getItem("theme");
            if (savedTheme) return savedTheme;
            return window.matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light";
        }

        function applyTheme(theme: string) {
            const nav = document.getElementById("main-nav");
            const lightIcon = document.getElementById(
                "theme-toggle-light-icon",
            );
            const darkIcon = document.getElementById("theme-toggle-dark-icon");
            const mobileLightIcon = document.getElementById(
                "mobile-theme-toggle-light-icon",
            );
            const mobileDarkIcon = document.getElementById(
                "mobile-theme-toggle-dark-icon",
            );

            if (theme === "dark") {
                document.documentElement.classList.add("dark");
                if (nav) {
                    nav.style.background = "rgba(13,27,42,0.65)";
                    nav.style.backdropFilter = "blur(14px) saturate(150%)";
                    nav.style.webkitBackdropFilter =
                        "blur(14px) saturate(150%)";
                    nav.style.borderBottom = "1px solid rgba(0,245,255,0.2)";
                    nav.style.boxShadow = "0 1px 20px rgba(0,245,255,0.05)";
                }
                lightIcon?.classList.remove("hidden");
                darkIcon?.classList.add("hidden");
                mobileLightIcon?.classList.remove("hidden");
                mobileDarkIcon?.classList.add("hidden");
            } else {
                document.documentElement.classList.remove("dark");
                if (nav) {
                    nav.style.background = "rgba(255,248,240,0.75)";
                    nav.style.backdropFilter = "blur(14px) saturate(150%)";
                    nav.style.webkitBackdropFilter =
                        "blur(14px) saturate(150%)";
                    nav.style.borderBottom = "1px solid rgba(255,107,157,0.2)";
                    nav.style.boxShadow = "";
                }
                lightIcon?.classList.add("hidden");
                darkIcon?.classList.remove("hidden");
                mobileLightIcon?.classList.add("hidden");
                mobileDarkIcon?.classList.remove("hidden");
            }
        }

        const currentTheme = getThemePreference();
        applyTheme(currentTheme);

        document.addEventListener("DOMContentLoaded", function () {
            applyTheme(getThemePreference());

            function toggleTheme() {
                const isDark =
                    document.documentElement.classList.contains("dark");
                const newTheme = isDark ? "light" : "dark";
                localStorage.setItem("theme", newTheme);
                applyTheme(newTheme);
            }

            document
                .getElementById("theme-toggle")
                ?.addEventListener("click", toggleTheme);
            document
                .getElementById("mobile-theme-toggle")
                ?.addEventListener("click", toggleTheme);

            window
                .matchMedia("(prefers-color-scheme: dark)")
                .addEventListener("change", (e) => {
                    if (!localStorage.getItem("theme"))
                        applyTheme(e.matches ? "dark" : "light");
                });

            const mobileMenuButton =
                document.getElementById("mobile-menu-button");
            const mobileMenu = document.getElementById("mobile-menu");
            if (mobileMenuButton && mobileMenu) {
                mobileMenuButton.addEventListener("click", function () {
                    mobileMenu.classList.toggle("hidden");
                });
                document.addEventListener("click", function (event) {
                    const target = event.target as Node;
                    if (
                        !mobileMenuButton.contains(target) &&
                        !mobileMenu.contains(target)
                    ) {
                        mobileMenu.classList.add("hidden");
                    }
                });
            }
        });
    </script>
</nav>

<style>
    .nav-link {
        color: #64748b;
        position: relative;
    }
    .nav-link::after {
        content: "";
        position: absolute;
        bottom: 2px;
        left: 50%;
        transform: translateX(-50%);
        width: 0;
        height: 1.5px;
        background: linear-gradient(90deg, #ff6b9d, #8b5cf6);
        border-radius: 9999px;
        transition: width 0.25s ease;
    }
    .nav-link:hover {
        color: #ff6b9d;
    }
    .nav-link:hover::after {
        width: 60%;
    }
    :global(.dark) .nav-link {
        color: #94a3b8;
    }
    :global(.dark) .nav-link:hover {
        color: #ffb3cf;
    }
    :global(.dark) #mobile-menu {
        background: rgba(13, 27, 42, 0.75) !important;
        backdrop-filter: blur(14px) saturate(150%) !important;
        -webkit-backdrop-filter: blur(14px) saturate(150%) !important;
        border-top-color: rgba(0, 245, 255, 0.1) !important;
    }
</style>
