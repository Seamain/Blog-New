---
export interface Props {
  outerDiv?: string;
  currentPage: number;
  totalPage: number;
  url: string;
}

const {
  outerDiv = "flex w-full justify-center my-8",
  currentPage,
  totalPage,
  url,
} = Astro.props as Props;

const current = Number(currentPage);
const total = Number(totalPage);

const buildHref = (page: number) => `/${url}/${page === 1 ? "" : page}`;
const prevPage = current > 1 ? current - 1 : null;
const nextPage = current < total ? current + 1 : null;

let pageStatuses = Array.from({ length: total }, (_, i) => i + 1).map((i) => {
  return {
    pageNumber: i,
    isActive: current === i,
    isDisabled: isDisabled(i),
  };
});

function isDisabled(i: number) {
  if (total <= 6) return false;
  if (i <= 2 || i >= total - 1) return false;
  if (current === i - 1 || current === i || current === i + 1) return false;
  return true;
}
---

<nav class={outerDiv} aria-label="Pagination">
  <div class="inline-flex items-center gap-1.5 px-2 py-1.5 rounded-full" style="background: rgba(255,248,240,0.9); border: 1px solid rgba(255,107,157,0.2); box-shadow: 0 2px 12px rgba(255,107,157,0.08);">

    {prevPage ? (
      <a
        href={buildHref(prevPage)}
        aria-label="Previous page"
        class="page-btn"
      >
        ‹ Prev
      </a>
    ) : (
      <span class="page-btn disabled" aria-disabled="true">‹ Prev</span>
    )}

    {pageStatuses.map((pageStatus, index) =>
      pageStatus.isActive ? (
        <span class="page-btn active" aria-current="page">
          {pageStatus.pageNumber}
        </span>
      ) : pageStatus.isDisabled ? (
        !pageStatuses[index - 1]?.isDisabled && (
          <span class="page-btn disabled" aria-hidden="true">…</span>
        )
      ) : (
        <a class="page-btn" href={buildHref(pageStatus.pageNumber)}>
          {pageStatus.pageNumber}
        </a>
      )
    )}

    {nextPage ? (
      <a
        href={buildHref(nextPage)}
        aria-label="Next page"
        class="page-btn"
      >
        Next ›
      </a>
    ) : (
      <span class="page-btn disabled" aria-disabled="true">Next ›</span>
    )}
  </div>
</nav>

<style>
  .page-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.25rem;
    height: 2.25rem;
    padding: 0 0.75rem;
    border-radius: 9999px;
    font-size: 0.8rem;
    font-weight: 600;
    color: #64748b;
    transition: all 0.2s ease;
    cursor: pointer;
    white-space: nowrap;
  }
  .page-btn:hover:not(.disabled):not(.active) {
    background: rgba(255, 107, 157, 0.1);
    color: #FF6B9D;
  }
  .page-btn.active {
    background: linear-gradient(135deg, #FF6B9D, #8B5CF6);
    color: white;
    box-shadow: 0 0 12px rgba(255, 107, 157, 0.3);
  }
  .page-btn.disabled {
    opacity: 0.35;
    cursor: default;
    pointer-events: none;
  }

  :global(.dark) nav > div {
    background: rgba(13, 27, 42, 0.9) !important;
    border-color: rgba(0, 245, 255, 0.15) !important;
    box-shadow: 0 2px 12px rgba(0, 245, 255, 0.05) !important;
  }
  :global(.dark) .page-btn {
    color: #94a3b8;
  }
  :global(.dark) .page-btn:hover:not(.disabled):not(.active) {
    background: rgba(0, 245, 255, 0.08);
    color: #00F5FF;
  }
</style>
