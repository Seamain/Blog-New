---
import BasicStyle from "../layouts/BasicStyle.astro";
import PostCard from "../components/PostCard.astro";
import { listPosts } from "../api/Post";
import unwrap from "../libs/unwrap";
import type Post from "../interfaces/Post";
import Navbar from "../components/Navbar.astro";

let posts: Post[] = [];
try {
  posts = unwrap((await listPosts()).data).map((post) => post);
} catch (error) {
  console.error("Failed to load posts:", error instanceof Error ? error.message : String(error));
  posts = [];
}
---

<BasicStyle title="Seamain's Blog" description="This is my home page.">
  <div class="flex flex-col items-center w-full overflow-x-hidden">
    <Navbar />

    <!-- Hero Section -->
    <section class="relative mt-10 sm:mt-12 w-full max-w-5xl px-4 sm:px-6 text-center overflow-hidden">
      <!-- Decorative stars -->
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <span class="absolute top-2 left-8 text-lg animate-bounce" style="color: #FFE566; animation-duration: 3s; animation-delay: 0s;">✦</span>
        <span class="absolute top-6 right-12 text-sm animate-bounce" style="color: #FF6B9D; animation-duration: 2.5s; animation-delay: 0.5s;">✦</span>
        <span class="absolute bottom-4 left-1/4 text-xs animate-bounce" style="color: #8B5CF6; animation-duration: 3.5s; animation-delay: 1s;">✦</span>
        <span class="absolute top-1/3 right-6 text-base animate-bounce" style="color: #00F5FF; animation-duration: 4s; animation-delay: 1.5s;">✦</span>
      </div>

      <!-- Main title -->
      <div class="relative">
        <p class="cyber-font text-xs font-semibold tracking-[0.4em] mb-3 uppercase" style="color: rgba(139,92,246,0.7);">
          ── Welcome to ──
        </p>
        <h1 class="text-3xl sm:text-4xl font-bold leading-tight mb-2" style="font-family: 'Noto Sans SC', sans-serif;">
          <span class="acg-glow-text">Seamain</span>
          <span class="text-slate-800 dark:text-slate-100"> 的博客</span>
        </h1>
        <p class="mt-4 text-base max-w-xl mx-auto leading-relaxed" style="color: #64748b;">
          这里记录我对技术、产品与生活的灵感，希望你能找到有趣的想法与灵感。
        </p>
      </div>

      <!-- Topic badges -->
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <span class="acg-tag text-xs px-5 py-2" style="font-size: 0.7rem; letter-spacing: 0.2em;">
          ✦ Tech
        </span>
        <span class="acg-tag text-xs px-5 py-2" style="font-size: 0.7rem; letter-spacing: 0.2em; border-color: rgba(139,92,246,0.35); background: linear-gradient(135deg, rgba(139,92,246,0.1), rgba(0,245,255,0.08)); color: #8B5CF6;">
          ✦ Product
        </span>
        <span class="acg-tag text-xs px-5 py-2" style="font-size: 0.7rem; letter-spacing: 0.2em; border-color: rgba(0,245,255,0.3); background: linear-gradient(135deg, rgba(0,245,255,0.08), rgba(139,92,246,0.08)); color: #06b6d4;">
          ✦ Life
        </span>
      </div>

      <!-- Decorative divider -->
      <div class="mt-10 flex items-center justify-center gap-3" aria-hidden="true">
        <div class="h-px w-16" style="background: linear-gradient(to right, transparent, rgba(255,107,157,0.4));"></div>
        <span class="text-xs cyber-font" style="color: rgba(255,107,157,0.5);">◇</span>
        <div class="h-px w-16" style="background: linear-gradient(to left, transparent, rgba(255,107,157,0.4));"></div>
      </div>
    </section>

    <!-- Posts container -->
    <div class="w-full max-w-5xl px-4 sm:px-6 pb-16">
      <!-- Featured post -->
      {posts[0] && <PostCard post={posts[0]} ml="w-full" />}

      <!-- Recent posts grid: 1 col on mobile, 2 cols on tablet+ -->
      {posts.length > 1 && (
        <div class="mt-0 grid grid-cols-1 sm:grid-cols-2 gap-4">
          {posts.slice(1, 5).map((post) => <PostCard post={post} ml="w-full mt-0" />)}
        </div>
      )}
    </div>
  </div>
</BasicStyle>

<style>
  :global(.dark) .text-slate-800 {
    color: #f1f5f9 !important;
  }
  :global(.dark) p[style*="64748b"] {
    color: #94a3b8 !important;
  }
</style>
