---
import { createFullListOfPostSlugWithId } from "../../api/Post";
import { getPost } from "../../api/Post";
import type Post from "../../interfaces/Post";
import BasicStyle from "../../layouts/BasicStyle.astro";
import formatDate from "../../libs/formatDate";
import { Icon } from "astro-icon/components";
import Markdown from "markdown-it";
import Navbar from "../../components/Navbar.astro";
import AISummary from "../../components/AISummary.astro";
import { fetchAvatarAsDataUrl } from "../../libs/fetchAvatar";

interface SlugWithPost {
  slug: string;
  post: Post;
}

interface Props {
  post: Post;
}

export async function getStaticPaths() {
  try {
    const result: SlugWithPost[] = [];
    const fullListOfSlug = await createFullListOfPostSlugWithId();

    for (const postAttr of fullListOfSlug) {
      try {
        const post = await getPost(postAttr.id);
        result.push({
          slug: postAttr.slug,
          post,
        });
      } catch (postError) {
        console.error(`Failed to load post ${postAttr.id}:`, postError instanceof Error ? postError.message : String(postError));
        // Skip this post and continue with others
        continue;
      }
    }

    return result.map((postAttr) => {
      return {
        params: {
          slug: postAttr.slug,
        },
        props: {
          post: postAttr.post,
        },
      };
    });
  } catch (error) {
    console.error("Failed to generate static paths:", error instanceof Error ? error.message : String(error));
    return []; // Return empty array as fallback
  }
}

const { post } = Astro.props;
const avatarRawUrl = post.author?.avatar?.formats?.thumbnail?.url ?? null;
// Fetch avatar at build time with CF Access credentials so the browser can render it
const avatarUrl = await fetchAvatarAsDataUrl(avatarRawUrl);
const formatedTime = formatDate(new Date(post.createdAt), "yyyy-MM-dd");
let html = Markdown().render(post.content);
const customCss =
  "\n<style>p {padding-bottom: 1rem; font-size: 1.125rem; line-height: 1.75rem; } \nh2{font-size: 1.5rem; line-height: 2rem; font-weight: 700 }</style>";
const publishedTime = new Date(Date.parse(post.createdAt));

html = html.concat(customCss);
---

<BasicStyle
  title={post.title}
  description={post.summary}
  ml="flex flex-col items-center"
  ogImage={"/posts/" + post.slug + ".png"}
  author={post.author?.name}
  publishedTime={publishedTime}
>
  <!-- Navbar is outside the centered container so it spans the full viewport width -->
  <Navbar />
  <div class="flex w-full flex-col items-center">
    <section class="mt-10 w-full max-w-5xl px-6">
      <div class="acg-card rounded-2xl px-8 py-10">
        <!-- Category label -->
        <p class="cyber-font text-xs uppercase tracking-[0.4em]" style="color: rgba(139,92,246,0.7);">
          ✦ {post.category?.name}
        </p>
        <h1 class="mt-4 text-3xl font-bold leading-tight" style="font-family: 'Noto Sans SC', sans-serif; color: #1e293b;">
          {post.title}
        </h1>
        <p class="mt-4 text-base leading-relaxed" style="color: #64748b;">{post.summary}</p>

        <!-- Divider -->
        <div class="mt-6 mb-6 h-px" style="background: linear-gradient(to right, rgba(255,107,157,0.3), rgba(139,92,246,0.3), transparent);"></div>

        <div class="grid gap-5 grid-cols-4 not-sm:grid-cols-1">
          <!-- Author -->
          <div class="flex items-center gap-3">
            {avatarUrl ? (
              <img
                src={avatarUrl}
                class="h-11 w-11 rounded-full object-cover"
                style="border: 1.5px solid rgba(255,107,157,0.4); box-shadow: 0 0 10px rgba(255,107,157,0.15);"
                width="44"
                height="44"
                loading="lazy"
                decoding="async"
                alt={`这是作者${post.author?.name}的头像`}
              />
            ) : (
              <div class="flex h-11 w-11 items-center justify-center rounded-full text-sm" style="border: 1.5px dashed rgba(255,107,157,0.4); color: rgba(255,107,157,0.6);">
                {post.author?.name?.slice(0, 1) ?? "?"}
              </div>
            )}
            <div>
              <p class="text-xs" style="color: #94a3b8;">作者</p>
              <p class="text-sm font-semibold" style="color: #334155;">{post.author?.name}</p>
            </div>
          </div>
          <!-- Date -->
          <div class="flex items-center gap-3">
            <div class="flex h-11 w-11 items-center justify-center rounded-xl" style="background: rgba(255,107,157,0.08); border: 1px solid rgba(255,107,157,0.2); color: #FF6B9D;">
              <Icon class="h-5 w-5" name="Clock" />
            </div>
            <div>
              <p class="text-xs" style="color: #94a3b8;">发布时间</p>
              <p class="text-sm font-semibold cyber-font" style="color: #334155;">{formatedTime}</p>
            </div>
          </div>
          <!-- Tags -->
          <div class="flex items-center gap-3">
            <div class="flex h-11 w-11 items-center justify-center rounded-xl shrink-0" style="background: rgba(139,92,246,0.08); border: 1px solid rgba(139,92,246,0.2); color: #8B5CF6;">
              <Icon class="h-5 w-5" name="Tag" />
            </div>
            <div>
              <p class="text-xs" style="color: #94a3b8;">标签</p>
              <div class="mt-1 flex flex-wrap gap-1.5">
                {post.tags.map((tag) => (
                  <span class="acg-tag">{tag.name}</span>
                ))}
              </div>
            </div>
          </div>
          <!-- Category -->
          <div class="flex items-center gap-3">
            <div class="flex h-11 w-11 items-center justify-center rounded-xl shrink-0" style="background: rgba(0,245,255,0.06); border: 1px solid rgba(0,245,255,0.15); color: #06b6d4;">
              <Icon class="h-5 w-5" name="Category" />
            </div>
            <div>
              <p class="text-xs" style="color: #94a3b8;">分类</p>
              <a
                href={`/categories/${post.category?.slug}`}
                class="text-sm font-semibold transition-colors duration-200"
                style="color: #334155;"
                onmouseover="this.style.color='#FF6B9D'"
                onmouseout="this.style.color='#334155'"
              >
                {post.category?.name}
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="mt-10 mb-4 w-full max-w-4xl px-6">
      <AISummary content={post.content} title={post.title} />
      <article
        class="prose prose-slate mt-8 max-w-none rounded-2xl p-8"
        style="background: rgba(255,255,255,0.9); border: 1px solid rgba(255,107,157,0.12);"
        set:html={html}
      />
    </section>
  </div>
</BasicStyle>

<style>
  :global(.dark) h1[style] { color: #f1f5f9 !important; }
  :global(.dark) p[style*="64748b"] { color: #94a3b8 !important; }
  :global(.dark) p[style*="334155"] { color: #cbd5e1 !important; }
  :global(.dark) a[style*="334155"] { color: #cbd5e1 !important; }
  :global(.dark) article[style] {
    background: rgba(13, 27, 42, 0.85) !important;
    border-color: rgba(0, 245, 255, 0.1) !important;
    color: #cbd5e1;
  }
  :global(.dark) article a { color: #FFB3CF; }
  :global(.dark) article h1,
  :global(.dark) article h2,
  :global(.dark) article h3 { color: #f1f5f9; }
</style>
