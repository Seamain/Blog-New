---
import Search from "astro-pagefind/components/Search";
import BasicStyle from "../layouts/BasicStyle.astro";
import Navbar from "../components/Navbar.astro";
---

<BasicStyle title="Search Page" description="You can search any posts.">
    <div class="flex flex-col items-center w-screen">
        <Navbar />
        <section class="mt-10 w-full max-w-5xl px-6 text-center">
            <h1
                class="text-3xl font-semibold text-slate-900 dark:text-slate-100"
            >
                搜索全站
            </h1>
            <p class="mt-3 text-base text-slate-600 dark:text-slate-400">
                输入关键字查找您感兴趣的内容
            </p>
        </section>
        <div class="mt-8 mb-20 w-full max-w-3xl px-6">
            <Search
                id="search"
                class="pagefind-ui"
                uiOptions={{ showImages: false }}
            />
        </div>
    </div>
</BasicStyle>
